# AgentHands - Minimal Sandbox Container
# Used for secure code execution with strict resource limits

FROM python:3.11-slim-bookworm

# Security: Run as non-root user
RUN useradd -m -u 1000 -s /bin/bash sandbox && \
    mkdir -p /app/input /app/output && \
    chown -R sandbox:sandbox /app

# Install minimal dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    nodejs \
    npm \
    bash \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Install common Python packages (read-only in sandbox)
RUN pip install --no-cache-dir \
    requests \
    httpx \
    beautifulsoup4 \
    lxml \
    pandas \
    numpy \
    pyyaml \
    python-dateutil

# Security: Remove potentially dangerous binaries
RUN rm -f /usr/bin/wget /usr/bin/curl 2>/dev/null || true

# Security: Set restrictive permissions
RUN chmod 755 /app && \
    chmod 777 /app/input /app/output

# Set working directory
WORKDIR /app

# Switch to non-root user
USER sandbox

# Default command (will be overridden)
CMD ["python3", "--version"]

# Labels
LABEL maintainer="agenthands"
LABEL description="Secure sandbox for code execution"
LABEL version="1.0"
